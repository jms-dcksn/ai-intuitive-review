# Copy to .env.local and fill in.
#
# With NO key set, the app runs the choreographed mock (deterministic, staged to
# hit the exact trust beats). Set ANTHROPIC_API_KEY to switch the same UI over to
# a real agent loop that reads the corpus and scores each decision itself.

# Force the mock even when a key is present (e.g. exported in your shell).
# MOCK_MODE=true

# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — the model the agent uses to make each decision. Defaults to a
# current Claude model if unset.
DECISION_MODEL=claude-sonnet-5

# --- Optional: LangSmith tracing --------------------------------------------
# When these are set, every run is traced: one span tree per analysis, with the
# per-decision model calls nested under it and each gate outcome (confidence,
# impact, whether it blocked) attached as span metadata. Leave unset to disable.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=working-in-the-open
