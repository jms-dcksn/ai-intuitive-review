# Copy to .env.local and fill in.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults to a current Claude model if unset.
CITATIONS_MODEL=claude-sonnet-5

# Optional — the faithfulness judge runs on a *separate*, stronger model for
# independence from the generator above. Defaults to claude-opus-4-8 if unset.
JUDGE_MODEL=claude-opus-4-8
