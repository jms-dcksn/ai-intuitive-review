# Copy to .env.local and fill in.
#
# With NO key set, the app runs the choreographed mock (deterministic, staged to
# hit the exact approval beats, including the reject-and-adapt branch). Set
# ANTHROPIC_API_KEY to switch the same UI over to a real tool-calling agent that
# investigates the ticket itself and proposes its own actions.

# Force the mock even when a key is present (e.g. exported in your shell).
# MOCK_MODE=true

# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — the model the live agent runs on. Defaults to a current Claude
# model if unset.
AGENT_MODEL=claude-sonnet-5
